{
  "title": "Bookjjeok Failover Dashboard",
  "uid": "bookjjeok-failover",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "VPC2 종합 건강 점수",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0  },
              { "color": "orange", "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "green",  "value": 80 }
            ]
          }
        }
      },
      "targets": [{ "expr": "job:bookjjeok_health_score", "legendFormat": "Health Score" }]
    },
    {
      "id": 2,
      "title": "VPC2 트래픽 비율",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": 0  },
              { "color": "yellow","value": 30 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      },
      "targets": [{ "expr": "job:bookjjeok_vpc2_weight", "legendFormat": "VPC2 %" }]
    },
    {
      "id": 3,
      "title": "VPC1 트래픽 비율",
      "type": "stat",
      "gridPos": { "x": 9, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 30 },
              { "color": "red",    "value": 70 }
            ]
          }
        }
      },
      "targets": [{ "expr": "job:bookjjeok_vpc1_weight", "legendFormat": "VPC1 %" }]
    },
    {
      "id": 4,
      "title": "라우팅 상태",
      "type": "stat",
      "gridPos": { "x": 6, "y": 4, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "range", "options": { "from": 80, "to": 100, "result": { "text": "정상 (VPC2 100%)",    "color": "green"  } } },
            { "type": "range", "options": { "from": 60, "to": 80,  "result": { "text": "주의 (VPC2 70%)",     "color": "yellow" } } },
            { "type": "range", "options": { "from": 40, "to": 60,  "result": { "text": "위기 (VPC2 30%)",     "color": "orange" } } },
            { "type": "range", "options": { "from": 0,  "to": 40,  "result": { "text": "페일오버 (VPC1 100%)","color": "red"    } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
        }
      },
      "targets": [{ "expr": "job:bookjjeok_health_score", "legendFormat": "상태" }]
    },
    {
      "id": 5,
      "title": "CPU 사용률",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.8 }] },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      },
      "targets": [{ "expr": "job:node_cpu_usage:avg5m", "legendFormat": "CPU" }]
    },
    {
      "id": 6,
      "title": "메모리 사용률",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.85 }] },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      },
      "targets": [{ "expr": "job:node_memory_usage:avg", "legendFormat": "Memory" }]
    },
    {
      "id": 7,
      "title": "API 5xx 에러율",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.05 }] },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      },
      "targets": [{ "expr": "job:envoy_error_rate:rate5m", "legendFormat": "Error Rate" }]
    },
    {
      "id": 8,
      "title": "P95 응답시간 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 2000 }] },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      },
      "targets": [{ "expr": "job:envoy_latency_p95:rate5m", "legendFormat": "P95 Latency" }]
    },
    {
      "id": 9,
      "title": "Pending 파드 수",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "job:bookjjeok_pod_pending:count", "legendFormat": "Pending Pods" }]
    },
    {
      "id": 10,
      "title": "DB 커넥션 풀 사용률",
      "type": "gauge",
      "gridPos": { "x": 4, "y": 24, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.6 }, { "color": "red", "value": 0.8 }] }
        }
      },
      "targets": [{ "expr": "job:bookjjeok_db_pool_usage:ratio", "legendFormat": "DB Pool" }]
    },
    {
      "id": 11,
      "title": "VPC2/VPC1 라우팅 가중치 추이",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "VPC2" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "VPC1" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue",  "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "job:bookjjeok_vpc2_weight", "legendFormat": "VPC2" },
        { "expr": "job:bookjjeok_vpc1_weight", "legendFormat": "VPC1" }
      ]
    }
  ],
  "schemaVersion": 38
}
